# Agent Configuration Example
# Copy this file to .env and fill in your values

# ========================================
# WALLET CONFIGURATION (REQUIRED)
# ========================================
# Agent's Private Key (bech32 format: suiprivkey1...)
SUI_PRIVATE_KEY=suiprivkey1...

# ========================================
# CONTRACT IDS
# ========================================
SUI_PACKAGE_ID=0x9a2f0c4ce838201bcc0d85f313621d47551511b891213458f6d57d4a1b087043
SUI_POOL_ID=0x0839e6ce61e303da44f3d999648536f573ee22937d31f7eb132c57451d9899d0

# ========================================
# ELIZA CONFIGURATION
# ========================================
OPENAI_API_KEY=sk-your-openai-key
SUI_NETWORK=testnet

# ========================================
# SUPABASE
# ========================================
DATABASE_URL=postgresql://postgres:password@db.project.supabase.co:5432/postgres
SUPABASE_URL=https://project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ========================================
# API SERVER (v2.0 Autonomous Features)
# ========================================
# Server port (default: 3001)
PORT=3001

# JWT secret for token signing (use a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Admin API key for privileged operations
ADMIN_API_KEY=sk_live_admin_your_admin_key_here

# CORS allowed origins (comma-separated, or * for all)
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
