# =================================================================
# SuiLoop Agent — Environment Configuration Template
# =================================================================
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# This .env.example is safe to commit — it contains no real secrets.
# =================================================================

# ================================================================
# ⚠️  CRITICAL SECURITY ARCHITECTURE NOTE
# ================================================================
# SuiLoop is NON-CUSTODIAL. This means:
#
# ✅ The ONLY private key stored here is the AGENT BOT's own wallet.
#    This wallet ONLY pays gas fees. It CANNOT access user funds.
#
# ❌ USER private keys are NEVER requested, stored, transmitted,
#    or held by SuiLoop at any point. This is enforced at the
#    smart contract level via the OwnerCap/AgentCap split:
#
#    - OwnerCap  → Held by USER's wallet (cold wallet). Grants withdrawal rights.
#    - AgentCap  → Held by this bot wallet. Grants EXECUTION ONLY, never withdrawal.
#
# The Vault smart contract (atomic_engine.move) enforces this separation
# with an on-chain assertion. No code path allows the agent to move funds
# to any address other than back into the user's own Vault.
#
# This architecture means SuiLoop is NOT a custodian under applicable
# law (including Mexico's LRITF, Art. 17 Fracc. XVI LFPIORPI).
# ================================================================


# ========================================
# WALLET CONFIGURATION (REQUIRED)
# ========================================

# Agent Bot Wallet Private Key (bech32 format: suiprivkey1...)
# This wallet ONLY pays gas fees for autonomous strategy execution.
# Generate a fresh wallet: ./sui keytool generate ed25519
# Then fund it with testnet/mainnet SUI from a faucet or transfer.
#
# ⚠️  THIS IS THE BOT'S KEY, NOT A USER KEY.
#     Users interact via their own wallets (Suiet, Sui Wallet, etc.)
#     through the non-custodial frontend at https://sui-loop-web.vercel.app
SUI_PRIVATE_KEY=suiprivkey1...


# ========================================
# CONTRACT IDS
# ========================================

# The deployed Package ID of the atomic_engine smart contract.
SUI_PACKAGE_ID=0x945163568d75adf1cb3c1f7d1a197e4a903fd6ba3f807a4421cfa9f563f0dcb0

# Agent Registry Shared Object ID
SUI_REGISTRY_ID=0x...

# Neural Marketplace Shared Object ID
SUI_MARKETPLACE_ID=0x...

# Flash Loan Pool Shared Object ID
SUI_POOL_ID=0x...


# ========================================
# AI / LLM CONFIGURATION
# ========================================

# OpenAI API Key for agent reasoning and market analysis
OPENAI_API_KEY=sk-...

# Sui Network: 'testnet' or 'mainnet'
SUI_NETWORK=mainnet


# ========================================
# WALRUS DECENTRALIZED STORAGE (Optional)
# ========================================
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=


# ========================================
# DATABASE (Optional)
# ========================================
DATABASE_URL=postgresql://...

# ========================================
# SUPABASE (Optional)
# ========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...


# ========================================
# API SERVER
# ========================================
PORT=3001

# JWT secret (generate: openssl rand -base64 64)
JWT_SECRET=your-random-secret-here

# Admin API key (generate: openssl rand -hex 32)
ADMIN_API_KEY=sk_live_admin_...

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://sui-loop-web.vercel.app
